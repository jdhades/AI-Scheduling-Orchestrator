{
    "info": {
        "name": "AI Scheduling Orchestrator",
        "description": "Complete API collection for the AI Scheduling Orchestrator backend (NestJS + Supabase).\n\nImport this file + the `ai-scheduling-environment.json` file.\n\nExecution order for a full E2E run:\n1. Create Employee\n2. Initiate Handshake → 3. Verify Handshake\n4. Create Shift Templates (×N)\n5. Instantiate Week from Templates\n6. Generate Schedule (Deterministic or Hybrid)\n7. Get Weekly Schedule",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "_postman_id": "ai-scheduling-orchestrator-v1"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "company_id",
            "value": "11111111-2222-3333-4444-555555555555",
            "type": "string"
        },
        {
            "key": "employee_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "shift_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "template_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "rule_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "week_start",
            "value": "2024-03-04",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Employees",
            "item": [
                {
                    "name": "Register Employee",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "x-company-id",
                                "value": "{{company_id}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/employees",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "employees"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"employeeId\": \"emp-001\",\n  \"phone\": \"+34600000001\",\n  \"experienceMonths\": 24\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "description": "Registers a new employee. Returns the generated employeeId."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status is 201 Created', function () {",
                                    "  pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "pm.test('Response contains employeeId', function () {",
                                    "  var json = pm.response.json();",
                                    "  pm.expect(json.employeeId).to.exist;",
                                    "  pm.collectionVariables.set('employee_id', json.employeeId);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "List Company Employees",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "x-company-id",
                                "value": "{{company_id}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/employees?companyId={{company_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "employees"
                            ],
                            "query": [
                                {
                                    "key": "companyId",
                                    "value": "{{company_id}}"
                                }
                            ]
                        },
                        "description": "Returns all employees for the company with their availability windows and preferences."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status is 200', function () {",
                                    "  pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Response is an array', function () {",
                                    "  pm.expect(pm.response.json()).to.be.an('array');",
                                    "});",
                                    "",
                                    "pm.test('Each employee has id and name', function () {",
                                    "  var employees = pm.response.json();",
                                    "  if (employees.length > 0) {",
                                    "    pm.expect(employees[0]).to.have.property('id');",
                                    "    pm.expect(employees[0]).to.have.property('name');",
                                    "  }",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Employee Calendar",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "x-company-id",
                                "value": "{{company_id}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/employees/{{employee_id}}/calendar?from=2024-03-04&to=2024-03-10",
                            "host": [
                                "{{base_url}}"
                            ],
