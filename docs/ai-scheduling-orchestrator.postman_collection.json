                                    "key": "from",
                                    "value": "2024-03-04"
                                },
                                {
                                    "key": "to",
                                    "value": "2024-03-10"
                                }
                            ]
                        },
                        "description": "Returns all shift assignments for an employee in a date range."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status is 200', function () {",
                                    "  pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Response is an array', function () {",
                                    "  pm.expect(pm.response.json()).to.be.an('array');",
                                    "});"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "WhatsApp Verification",
            "item": [
                {
                    "name": "Initiate Handshake",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "x-company-id",
                                "value": "{{company_id}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/employees/{{employee_id}}/handshake",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "employees",
                                "{{employee_id}}",
                                "handshake"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"handshakeId\": \"hs-001\",\n  \"phone\": \"+34600000001\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "description": "Initiates WhatsApp verification. Generates a one-time token with 15min TTL."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status is 202 Accepted', function () {",
                                    "  pm.response.to.have.status(202);",
                                    "});",
                                    "",
                                    "pm.test('Response has message', function () {",
                                    "  var json = pm.response.json();",
                                    "  pm.expect(json.message).to.exist;",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Verify WhatsApp Token",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "x-company-id",
                                "value": "{{company_id}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/employees/{{employee_id}}/verify",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "employees",
                                "{{employee_id}}",
                                "verify"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"token\": \"PASTE_TOKEN_HERE\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "description": "Verifies WhatsApp number. Employee submits the token received via WhatsApp."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status is 200', function () {",
                                    "  pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Employee verified', function () {",
                                    "  var json = pm.response.json();",
                                    "  pm.expect(json.message).to.include('verified');",
                                    "});"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
