# Template para /opt/docker/ai-scheduling/.env en el VPS.
#
# Copiar a `.env` en el mismo directorio del compose y rellenar valores
# reales. NO commitear `.env`.
#
#   cp .env.example .env
#   chmod 600 .env
#   nano .env

# ---------- Tag de imagen ----------
# Pinear a SHA corto del commit (reproducible). Subir tag = forzar
# rollout: `docker compose pull && docker compose up -d`.
# Para promover a una versión más nueva, cambiar acá + pull + up.
BACKEND_TAG=277edd3
FRONTEND_TAG=9419864

# ---------- Red NPM ----------
# Red docker compartida con Nginx Proxy Manager. Verificar con:
#   docker network ls
NPM_NETWORK=proxy-network

# ---------- Entorno ----------
APP_ENV=staging            # staging | production
ENABLE_WORKERS=true        # single-instance: workers en el mismo container

# ---------- Supabase ----------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# ---------- CORS / Frontend ----------
# Ej. staging: https://app.islabroadcast.com
# Ej. prod:    https://app.<dominio-prod>
ALLOWED_ORIGIN=https://app.<dominio>
FRONTEND_URL=https://app.<dominio>

# ---------- LLM Providers ----------
ACTIVE_AI_PROVIDER=qwen     # qwen | gemini | local
QWEN_API_KEY=sk-xxx
GEMINI_API_KEY=AIza-xxx
# Solo si ACTIVE_AI_PROVIDER=local (LM Studio / Ollama en otra LAN).
LLM_LOCAL_BASE_URL=
LLM_LOCAL_MODEL=

# ---------- Schedule generation ----------
USE_ASYNC_SCHEDULE_GEN=true
SCHEDULE_WORKER_CONCURRENCY=1
LLM_WORKER_CONCURRENCY=2
SKIP_LLM_PROPOSER=false

# ---------- Twilio (WhatsApp) ----------
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=whatsapp:+14155xxxxxx
TWILIO_WEBHOOK_URL=https://api.<dominio>/whatsapp/webhook   # ej. api.islabroadcast.com
MANAGER_WHATSAPP_NUMBER=whatsapp:+5491100000000

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_STARTER=price_xxx
STRIPE_PRICE_ID_GROWTH=price_xxx

# ---------- Auth bypass (solo dev/staging) ----------
# DEV_AUTH_BYPASS=true salta el JWT verify y usa un usuario seed.
# JAMÁS true en prod.
DEV_AUTH_BYPASS=false
