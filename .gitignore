# temp directory
.temp
.tmp

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Editor backups
*~

# Documentos temporales
*.docx

# Entornos y config de agentes
.agent/
.gemini/

# Supabase local (dev DB + IDE scratchpad)
supabase/.temp/
supabase/.branches/
supabase/snippets/Untitled*

# Environment files con secrets (Supabase keys, Twilio tokens, Qwen API keys, DB URL)
# Solo .env.example y .env.test quedan tracked. .env.test apunta al stack
# local de Supabase con las CLI defaults (públicas por design) — necesario
# para que las integration tests corran en cualquier máquina.
.env
.env.*
!.env.example
!.env.test
