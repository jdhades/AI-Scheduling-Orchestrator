# =============================================================================
# .env.example — template documentado para setup local del orchestrator.
# Copiá a .env y rellená los valores. .env (y .env.*) está en .gitignore;
# este archivo es el ÚNICO que se commitea como referencia.
# =============================================================================

# ─── Supabase ────────────────────────────────────────────────────────────────
# URL del proyecto Supabase (local: http://127.0.0.1:54321)
SUPABASE_URL=
# Anon key (pública, para clientes no-server-side)
SUPABASE_ANON_KEY=
# Service-role key (PRIVADA — bypass RLS, solo backend)
SUPABASE_SERVICE_ROLE_KEY=
# Postgres URL para herramientas que conectan directo (migrations, scripts)
DATABASE_URL=

# ─── Redis (sesiones de WhatsApp) ────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── Twilio (WhatsApp via Programmable Messaging) ────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# URL pública del webhook (ngrok en dev). Twilio firma cada request con esta URL.
TWILIO_WEBHOOK_URL=

# ─── LLM provider activo ─────────────────────────────────────────────────────
# qwen | gemini | local
ACTIVE_AI_PROVIDER=qwen

# Qwen (DashScope) — default
QWEN_API_KEY=

# Gemini — alternativo
GEMINI_API_KEY=

# Local LLM (LM Studio / Ollama) — desarrollo offline
LLM_LOCAL_BASE_URL=http://127.0.0.1:1234/v1
LLM_LOCAL_MODEL=

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=development
PORT=3000

# ─── Auth (deuda HIGH conocida) ──────────────────────────────────────────────
# Bypass de JWT en dev/tests cuando la request trae X-Company-Id.
# DEJAR EN false EN PRODUCCIÓN. Ver src/infrastructure/auth/supabase-auth.guard.ts.
DEV_AUTH_BYPASS=true

# ─── Dev-only: bypass de LLM en generate_schedule ────────────────────────────
# Cuando es 'true', WeekScheduleBuilder salta al LLMLineProposer y usa solo el
# motor determinístico. Útil durante la migración a worker async (Fase 0/1) para
# iterar sobre lock/queue/dashboard sin gastar tokens. DEJAR EN false EN PROD.
SKIP_LLM_PROPOSER=false

# ─── Async schedule generation (Fase 1) ──────────────────────────────────────
# Cuando es 'true', generate_schedule encola un job en pg-boss en lugar de
# correr síncrono. La API responde 202 + jobId; el worker procesa en
# background y notifica al manager (Twilio outbound + WS). Requiere
# DATABASE_URL seteada para que pg-boss pueda iniciar.
USE_ASYNC_SCHEDULE_GEN=false
